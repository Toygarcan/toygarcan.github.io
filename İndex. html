<!DOCTYPE html>
<html>
<head>
    <title>WorkBlock</title>
</head>
<body>
    <h1>WorkBlock Uygulaması</h1>
    <div id="log"></div>

    <script>
        // Pi SDK kodunuzu buraya yapıştırın
        window.Pi.init({ version: "2.0", sandbox: true });
        const logDiv = document.getElementById("log");

        function log(msg) {
            console.log(msg);
            logDiv.innerHTML += "<br>" + msg;
        }

        async function initWorkblock() {
            log("Yetkilendirme başlatılıyor...");
            try {
                const auth = await window.Pi.authenticate(['username', 'payments'], onAuth, onAuthDenied);
            } catch (err) {
                log("Hata: " + err);
            }
        }
        
        function onAuth(auth) { log("Doğrulandı: " + auth.user.username); }
        function onAuthDenied() { log("Erişim reddedildi."); }

        initWorkblock();
    </script>
</body>
</html>
